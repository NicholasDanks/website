---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  external?: boolean;
}

const { href, variant = "primary", size = "md", external = false } = Astro.props;

const baseClasses = "inline-flex items-center gap-2 font-semibold rounded-lg transition-all duration-200";

const variants = {
  primary: "bg-accent-600 text-white hover:bg-accent-700 shadow-sm hover:shadow-md",
  secondary: "bg-surface-100 text-surface-800 hover:bg-surface-200 dark:bg-surface-800 dark:text-surface-200 dark:hover:bg-surface-700",
  ghost: "text-accent-600 dark:text-accent-400 hover:bg-accent-50 dark:hover:bg-accent-900/20 hover:shadow-sm hover:ring-1 hover:ring-accent-200 dark:hover:ring-accent-800",
};

const sizes = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-5 py-2.5 text-sm",
  lg: "px-6 py-3 text-base",
};

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  class:list={[baseClasses, variants[variant], sizes[size]]}
  {...external && { target: "_blank", rel: "noopener noreferrer" }}
>
  <slot />
</Tag>
