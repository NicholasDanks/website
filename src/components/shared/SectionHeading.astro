---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-10">
  <h2 class="section-heading text-3xl sm:text-4xl font-bold tracking-tight text-surface-900 dark:text-surface-50">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-4 text-lg text-surface-600 dark:text-surface-400 max-w-2xl">
      {subtitle}
    </p>
  )}
</div>
