---
import Badge from "../shared/Badge.astro";

interface Props {
  title: string;
  authors: string[];
  journal: string;
  year: number;
  type: string;
  doi?: string;
  url?: string;
  citations?: number;
  featured?: boolean;
}

const { title, authors, journal, year, type, doi, url, citations = 0, featured = false } = Astro.props;

const typeColors: Record<string, "primary" | "accent" | "neutral"> = {
  article: "primary",
  book: "accent",
  chapter: "neutral",
  conference: "neutral",
};

const link = doi ? `https://doi.org/${doi}` : url || undefined;

function formatAuthors(authors: string[]): string {
  return authors
    .map((a) =>
      a.includes("Danks")
        ? `<strong class="text-accent-600 dark:text-accent-400">${a}</strong>`
        : a
    )
    .join(", ");
}
---

<article
  class:list={[
    "group p-5 rounded-xl border transition-all duration-300",
    "bg-white dark:bg-surface-900",
    featured
      ? "border-accent-200 dark:border-accent-800 ring-1 ring-accent-100 dark:ring-accent-900/30 bg-gradient-to-r from-accent-50/50 to-white dark:from-accent-950/30 dark:to-surface-900"
      : "border-surface-200 dark:border-surface-800",
    "hover:border-accent-300 dark:hover:border-accent-700 hover:shadow-md",
  ]}
  data-year={year}
  data-type={type}
>
  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <Badge label={type} variant={typeColors[type] || "neutral"} />
        <span class="text-sm text-surface-500 dark:text-surface-400">{year}</span>
        {featured && (
          <span class="inline-flex items-center gap-1 text-xs font-medium text-accent-600 dark:text-accent-400">
            <svg class="w-3 h-3" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            Featured
          </span>
        )}
      </div>

      <h3 class="font-semibold text-surface-900 dark:text-surface-100 mb-1 leading-snug">
        {link ? (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
          >
            {title}
          </a>
        ) : (
          title
        )}
      </h3>

      <p
        class="text-sm text-surface-600 dark:text-surface-400"
        set:html={formatAuthors(authors)}
      />

      <p class="text-sm text-surface-500 dark:text-surface-400 mt-1 italic">
        {journal}
      </p>
    </div>

    {citations > 0 && (
      <div class="shrink-0 text-right">
        <div class="text-2xl font-bold text-accent-600 dark:text-accent-400">
          {citations.toLocaleString()}
        </div>
        <div class="text-xs text-surface-500 dark:text-surface-400">citations</div>
      </div>
    )}
  </div>
</article>
