---
interface Props {
  types: string[];
  years: number[];
}

const { types, years } = Astro.props;
---

<div class="flex flex-wrap items-center gap-4 mb-8 p-4 rounded-xl bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800">
  <div class="flex items-center gap-2">
    <label for="filter-type" class="text-sm font-medium text-surface-600 dark:text-surface-400">Type:</label>
    <div class="relative">
      <select
        id="filter-type"
        class="appearance-none pr-8 cursor-pointer text-sm rounded-lg border border-surface-300 dark:border-surface-700 bg-surface-50 dark:bg-surface-800 text-surface-900 dark:text-surface-100 px-3 py-1.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 hover:border-accent-400 transition-colors"
      >
        <option value="all">All Types</option>
        {types.map((t) => (
          <option value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>
        ))}
      </select>
      <svg class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <label for="filter-year" class="text-sm font-medium text-surface-600 dark:text-surface-400">Year:</label>
    <div class="relative">
      <select
        id="filter-year"
        class="appearance-none pr-8 cursor-pointer text-sm rounded-lg border border-surface-300 dark:border-surface-700 bg-surface-50 dark:bg-surface-800 text-surface-900 dark:text-surface-100 px-3 py-1.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 hover:border-accent-400 transition-colors"
      >
        <option value="all">All Years</option>
        {years.map((y) => (
          <option value={y}>{y}</option>
        ))}
      </select>
      <svg class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

  <div class="ml-auto">
    <span id="filter-count" class="text-sm text-surface-500 dark:text-surface-400"></span>
  </div>
</div>

<script>
  const typeSelect = document.getElementById("filter-type") as HTMLSelectElement;
  const yearSelect = document.getElementById("filter-year") as HTMLSelectElement;
  const countSpan = document.getElementById("filter-count");
  const articles = document.querySelectorAll("[data-year][data-type]");

  function filterPublications() {
    const selectedType = typeSelect.value;
    const selectedYear = yearSelect.value;
    let visible = 0;

    articles.forEach((el) => {
      const matchType = selectedType === "all" || el.getAttribute("data-type") === selectedType;
      const matchYear = selectedYear === "all" || el.getAttribute("data-year") === selectedYear;

      if (matchType && matchYear) {
        (el as HTMLElement).style.display = "";
        visible++;
      } else {
        (el as HTMLElement).style.display = "none";
      }
    });

    if (countSpan) {
      countSpan.textContent = `${visible} publication${visible !== 1 ? "s" : ""}`;
    }
  }

  typeSelect?.addEventListener("change", filterPublications);
  yearSelect?.addEventListener("change", filterPublications);

  // Initial count
  filterPublications();
</script>
