---
import Button from "../shared/Button.astro";
import Badge from "../shared/Badge.astro";

interface Props {
  name: string;
  title: string;
  institution: string;
  bio: string;
  researchInterests: string[];
}

const { name, title, institution, bio, researchInterests } = Astro.props;
const initials = name.split(" ").map((w) => w[0]).join("");
---

<section class="relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary-50/50 to-transparent dark:from-primary-950/20 dark:to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="grid lg:grid-cols-5 gap-12 items-center">
      <!-- Text content -->
      <div class="lg:col-span-3 space-y-6">
        <div class="space-y-2">
          <p class="text-sm font-mono font-medium text-accent-500 tracking-wide uppercase">
            {title}
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-surface-900 dark:text-surface-50">
            {name.split(" ").map((word, i) => (
              i === 1 ? <span class="text-accent-600 dark:text-accent-400">{word} </span> : <span>{word} </span>
            ))}
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400">
            {institution}
          </p>
        </div>

        <p class="text-surface-700 dark:text-surface-300 leading-relaxed max-w-xl">
          {bio}
        </p>

        <div class="flex flex-wrap gap-2">
          {researchInterests.slice(0, 5).map((interest) => (
            <Badge label={interest} variant="primary" />
          ))}
        </div>

        <div class="flex flex-wrap gap-3 pt-2">
          <Button href="/research" variant="primary">
            View Research
            <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button href="/software" variant="secondary">
            SEMinR Package
          </Button>
          <Button href="/contact" variant="ghost">
            Get in Touch
          </Button>
        </div>
      </div>

      <!-- Photo -->
      <div class="lg:col-span-2 flex justify-center lg:justify-end">
        <div class="relative">
          <div class="w-64 h-80 sm:w-72 sm:h-96 rounded-2xl overflow-hidden bg-surface-200 dark:bg-surface-800 shadow-2xl ring-1 ring-surface-200 dark:ring-surface-700">
            <img
              id="hero-headshot"
              src="/images/Nicholas-Danks.png.webp"
              alt={name}
              class="w-full h-full object-cover"
            />
            <div id="hero-fallback" class="hidden w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-600 to-primary-800 dark:from-primary-700 dark:to-primary-900">
              <span class="text-5xl sm:text-6xl font-bold text-white/90 select-none">{initials}</span>
            </div>
          </div>
          <!-- Decorative accent -->
          <div class="absolute -bottom-3 -left-3 w-full h-full rounded-2xl border-2 border-accent-500/30 -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const img = document.getElementById("hero-headshot") as HTMLImageElement;
  const fallback = document.getElementById("hero-fallback");
  if (img && fallback) {
    img.addEventListener("error", () => {
      img.classList.add("hidden");
      fallback.classList.remove("hidden");
    });
    // Handle case where error fires before JS loads
    if (img.complete && img.naturalWidth === 0) {
      img.classList.add("hidden");
      fallback.classList.remove("hidden");
    }
  }
</script>
