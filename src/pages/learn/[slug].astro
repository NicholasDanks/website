---
import PageLayout from "../../layouts/PageLayout.astro";
import Badge from "../../components/shared/Badge.astro";
import Button from "../../components/shared/Button.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const tutorials = await getCollection("tutorials");
  return tutorials.map((tutorial) => ({
    params: { slug: tutorial.id.replace(/\.md$/, "") },
    props: { tutorial },
  }));
}

const { tutorial } = Astro.props;
const { Content } = await render(tutorial);
const {
  title,
  topic,
  chapter,
  order,
  summary,
  learningOutcomes,
  videoStatus,
  videoUrl,
  durationMinutes,
  codeFile,
  rPractice,
} = tutorial.data;

const youtubeEmbed = (() => {
  if (!videoUrl) return null;
  const match = videoUrl.match(/(?:youtu\.be\/|v=)([A-Za-z0-9_-]{6,})/);
  return match ? `https://www.youtube.com/embed/${match[1]}` : null;
})();
---

<PageLayout
  title={`${title} — Learn PLS-SEM with SEMinR`}
  description={summary}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <!-- Breadcrumb -->
    <div class="mb-6">
      <a
        href="/learn"
        class="text-sm text-surface-500 dark:text-surface-400 hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
      >
        &larr; Back to all tutorials
      </a>
    </div>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <Badge label={`Video ${order}`} variant="accent" />
        <Badge label={`Chapter ${chapter}`} variant="primary" />
        <Badge label={topic} variant="neutral" />
        {durationMinutes && <Badge label={`${durationMinutes} min`} variant="neutral" />}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-surface-900 dark:text-surface-50 mb-4">
        {title}
      </h1>
      <p class="text-lg text-surface-600 dark:text-surface-400 leading-relaxed">
        {summary}
      </p>
    </header>

    <!-- Video embed or placeholder -->
    {youtubeEmbed ? (
      <div class="mb-10 rounded-xl overflow-hidden border border-surface-200 dark:border-surface-800 bg-black">
        <div class="relative" style="padding-top: 56.25%;">
          <iframe
            class="absolute inset-0 w-full h-full"
            src={youtubeEmbed}
            title={title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    ) : (
      <div class="mb-10 p-6 rounded-xl border border-dashed border-surface-300 dark:border-surface-700 bg-surface-50 dark:bg-surface-900/50 text-center">
        <p class="text-sm text-surface-500 dark:text-surface-400">
          {videoStatus === "recorded"
            ? "Video is recorded and will be published shortly."
            : "Video planned. Subscribe on YouTube to be notified when it drops."}
        </p>
      </div>
    )}

    <!-- Learning outcomes -->
    {learningOutcomes && learningOutcomes.length > 0 && (
      <section class="mb-10 p-6 rounded-xl bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800">
        <h2 class="text-lg font-semibold text-surface-900 dark:text-surface-100 mb-4">
          What you'll learn
        </h2>
        <ul class="space-y-2">
          {learningOutcomes.map((outcome) => (
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-accent-500 mt-0.5 shrink-0"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-surface-700 dark:text-surface-300 leading-relaxed">
                {outcome}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- R practice callout -->
    {rPractice && rPractice.length > 0 && (
      <section class="mb-10 p-6 rounded-xl border border-accent-200 dark:border-accent-800 bg-accent-50/50 dark:bg-accent-900/20">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-accent-700 dark:text-accent-300 mb-3">
          R practice in this video
        </h2>
        <ul class="space-y-2">
          {rPractice.map((habit) => (
            <li class="flex items-start gap-2 text-sm text-surface-700 dark:text-surface-300">
              <span class="text-accent-500 font-mono">&gt;</span>
              <span>{habit}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Markdown body -->
    <article class="prose prose-surface dark:prose-invert max-w-none prose-pre:bg-surface-900 prose-pre:text-surface-100 prose-code:text-accent-600 dark:prose-code:text-accent-400 prose-code:before:content-none prose-code:after:content-none">
      <Content />
    </article>

    <!-- Footer CTAs -->
    <div class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
      <div class="flex flex-wrap gap-3">
        {codeFile && (
          <Button
            href={`https://github.com/sem-in-r/seminr/blob/main/inst/examples/${codeFile}`}
            variant="primary"
            external
          >
            Get the R code
          </Button>
        )}
        <Button href="https://cran.r-project.org/package=seminr" variant="secondary" external>
          SEMinR on CRAN
        </Button>
        <Button href="/learn" variant="secondary">
          All tutorials
        </Button>
      </div>
    </div>
  </div>
</PageLayout>
